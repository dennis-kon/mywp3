{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "order-confirmation",
			"title": "Order Confirmation"
		},
		{
			"name": "page-cart",
			"title": "Page: Cart"
		},
		{
			"name": "page-checkout",
			"title": "Page: Checkout"
		},
		{
			"name": "template-page-w-hero",
			"title": "Page with Hero"
		},
		{
			"name": "template-page-w-title",
			"title": "Page without Title"
		},
		{
			"name": "archive-product",
			"title": "Product Catalogue"
		},
		{
			"name": "product-search-results",
			"title": "Product Search Results"
		},
		{
			"name": "taxonomy-product_attribute",
			"title": "Products by Attribute"
		},
		{
			"name": "single-product",
			"title": "Single Product"
		}
	],
	"settings": {
		"appearanceTools": true,
		"blocks": {
			"core/heading": {
				"color": {
					"background": false
				}
			}
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"duotone": [
				{
					"colors": [
						"#000000",
						"#FFFFFF"
					],
					"name": "Duotone 1",
					"slug": "duotone-1"
				},
				{
					"colors": [
						"#000000",
						"#BBBBBB"
					],
					"name": "Duotone 2",
					"slug": "duotone-2"
				}
			],
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Color 1",
					"slug": "theme-1"
				},
				{
					"color": "#EEEEEE",
					"name": "Color 2",
					"slug": "theme-2"
				},
				{
					"color": "#BBBBBB",
					"name": "Color 3",
					"slug": "theme-3"
				},
				{
					"color": "#1E1E1E",
					"name": "Color 4",
					"slug": "theme-4"
				},
				{
					"color": "#000000",
					"name": "Color 5",
					"slug": "theme-5"
				}
			]
		},
		"custom": {
			"spacing-increment": "2.5",
			"spacing-unit": "10"
		},
		"layout": {
			"contentSize": "850px",
			"wideSize": "1280px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingScale": {
				"theme": {
					"steps": 1
				}
			},
			"spacingSizes": [
				{
					"name": "2X-Small",
					"size": "min(calc(var(--wp--custom--spacing-unit) * (var(--wp--custom--spacing-increment) * 1) * 1px), calc(var(--wp--custom--spacing-increment) * 1 * 2vw))",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "min(calc(var(--wp--custom--spacing-unit) * (var(--wp--custom--spacing-increment) * 2) * 1px), calc(var(--wp--custom--spacing-increment) * 2 * 1vw))",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "min(calc(var(--wp--custom--spacing-unit) * (var(--wp--custom--spacing-increment) * 3) * 1px), calc(var(--wp--custom--spacing-increment) * 3 * 1vw))",
					"slug": "40"
				},
				{
					"name": "Medium",
					"size": "min(calc(var(--wp--custom--spacing-unit) * (var(--wp--custom--spacing-increment) * 4) * 1px), calc(var(--wp--custom--spacing-increment) * 4 * 1vw))",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "min(calc(var(--wp--custom--spacing-unit) * (var(--wp--custom--spacing-increment) * 5) * 1px), calc(var(--wp--custom--spacing-increment) * 5 * 1vw))",
					"slug": "60"
				},
				{
					"name": "Extra Large",
					"size": "min(calc(var(--wp--custom--spacing-unit) * (var(--wp--custom--spacing-increment) * 6) * 1px), calc(var(--wp--custom--spacing-increment) * 6 * 1vw))",
					"slug": "70"
				},
				{
					"name": "2X Large",
					"size": "min(calc(var(--wp--custom--spacing-unit) * (var(--wp--custom--spacing-increment) * 7) * 1px), calc(var(--wp--custom--spacing-increment) * 7 * 1vw))",
					"slug": "80"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "100 800",
							"src": [
								"file:./assets/fonts/inter/InterVariable.woff2"
							]
						},
						{
							"fontFamily": "Inter",
							"fontStretch": "normal",
							"fontStyle": "italic",
							"fontWeight": "100 800",
							"src": [
								"file:./assets/fonts/inter/InterVariable-Italic.woff2"
							]
						}
					],
					"fontFamily": "\"Inter\", sans-serif",
					"name": "Inter",
					"slug": "inter"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-400-normal.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-500-normal.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-600-normal.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-700-normal.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "normal",
							"fontWeight": "800",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-800-normal.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-400-italic.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "italic",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-500-italic.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "italic",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-600-italic.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "italic",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-700-italic.woff2"
							]
						},
						{
							"fontFamily": "\"EB Garamond\"",
							"fontStyle": "italic",
							"fontWeight": "800",
							"src": [
								"file:./assets/fonts/eb-garamond/eb-garamond-800-italic.woff2"
							]
						}
					],
					"fontFamily": "\"EB Garamond\", serif",
					"name": "EB Garamond",
					"slug": "eb-garamond"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"size": "16px",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "24px",
						"min": "20px"
					},
					"name": "Medium",
					"size": "24px",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "38px",
					"slug": "large"
				},
				{
					"name": "Extra Large",
					"size": "60px",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "80px",
						"min": "40px"
					},
					"name": "2X Large",
					"size": "80px",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"max": "160px",
						"min": "40px"
					},
					"name": "3X Large",
					"size": "160px",
					"slug": "xxx-large"
				},
				{
					"name": "X Small",
					"size": "14px",
					"slug": "x-small"
				}
			],
			"writingMode": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"border": {
					"radius": {
						"bottomLeft": "0px",
						"bottomRight": "0px",
						"topLeft": "0px",
						"topRight": "0px"
					}
				},
				"spacing": {
					"padding": {
						"bottom": "10px",
						"left": "24px",
						"right": "24px",
						"top": "10px"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "400",
					"letterSpacing": "1px",
					"textTransform": "uppercase"
				},
				"variations": {
					"outline": {
						"border": {
							"width": "1px"
						},
						"spacing": {
							"padding": {
								"bottom": "10px",
								"left": "24px",
								"right": "24px",
								"top": "10px"
							}
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--x-small)",
							"fontStyle": "normal",
							"fontWeight": "400",
							"letterSpacing": "1px",
							"textTransform": "uppercase"
						}
					}
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "8px",
					"margin": {
						"top": "calc( var(--wp--style--block-gap) * 1.5)"
					}
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": {
						"left": "var(--wp--preset--spacing--40)",
						"top": "var(--wp--preset--spacing--30)"
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"lineHeight": "1.3"
				}
			},
			"core/page-list": {
				"typography": {
					"lineHeight": "1.5"
				}
			},
			"core/paragraph": {
				"typography": {
					"lineHeight": "calc( 1em + 0.65rem )"
				}
			},
			"core/post-content": {
				"css": "& > div:first-child.alignfull { margin-top: calc( -1 * var(--wp--preset--spacing--20)) !important; } & > div:last-child.alignfull { margin-bottom: calc( -1 * var(--wp--preset--spacing--60)) !important; } & > p + div.alignfull { margin-top: var(--wp--style--block-gap) !important; }",
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--60)",
						"top": "var(--wp--preset--spacing--20)"
					}
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--eb-garamond)",
					"fontStyle": "italic",
					"fontWeight": "400"
				}
			},
			"core/separator": {
				"border": {
					"top": {
						"width": "1px"
					}
				},
				"color": {
					"background": "var(--wp--preset--color--theme-2)",
					"text": "transparent"
				}
			},
			"core/site-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "500",
					"lineHeight": {
						"ref": "styles.blocks.core/navigation.typography.lineHeight"
					},
					"textTransform": "uppercase"
				}
			},
			"woocommerce/product-button": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)"
				}
			},
			"woocommerce/product-gallery": {
				"spacing": {
					"blockGap": "10px"
				}
			},
			"woocommerce/product-sale-badge": {
				"border": {
					"bottom": {
						"color": "var(--wp--preset--color--theme-5)",
						"style": "solid"
					},
					"color": "color-mix(in srgb, currentColor 30%, transparent)",
					"left": {
						"color": "var(--wp--preset--color--theme-5)",
						"style": "solid"
					},
					"radius": "0",
					"right": {
						"color": "var(--wp--preset--color--theme-5)",
						"style": "solid"
					},
					"top": {
						"color": "var(--wp--preset--color--theme-5)",
						"style": "solid"
					}
				},
				"color": {
					"background": "var(--wp--preset--color--theme-1)",
					"text": "var(--wp--preset--color--theme-4)"
				},
				"spacing": {
					"padding": {
						"bottom": "4px",
						"left": "8px",
						"right": "8px",
						"top": "4px"
					}
				},
				"typography": {
					"fontStyle": "normal",
					"fontWeight": "400",
					"lineHeight": "1",
					"textTransform": "none"
				}
			},
			"woocommerce/product-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--theme-1)",
			"text": "var(--wp--preset--color--theme-4)"
		},
		"css": ".no-underline a { text-decoration: none; } button:focus-visible, .wp-block-button__link:focus-visible { outline: 2px solid var(--wp--preset--color--theme-4); outline-offset: 2px; } button[disabled], .wp-block-button__link[disabled], .wp-block-button__link:disabled { opacity: 0.5; cursor: not-allowed; } button[disabled]:hover, .wp-block-button__link[disabled]:hover, .wp-block-button__link:disabled:hover { background-color: var(--wp--preset--color--theme-4); } .wc-block-add-to-cart-with-options-variation-selector-attribute-options__pill { border-color: color-mix(in srgb, currentColor 30%, transparent); border-radius: 0; } .wp-block-woocommerce-product-review-form .comment-reply-title { font-weight: unset; }",
		"elements": {
			"button": {
				":hover": {
					"color": {
						"background": "color-mix(in srgb, var(--wp--preset--color--theme-5) 85%, #000)"
					}
				},
				"border": {
					"radius": "0"
				},
				"color": {
					"background": "var(--wp--preset--color--theme-4)",
					"text": "var(--wp--preset--color--theme-1)"
				},
				"spacing": {
					"padding": {
						"bottom": "16px",
						"left": "24px",
						"right": "24px",
						"top": "16px"
					}
				},
				"typography": {
					"fontFamily": {
						"ref": "styles.elements.heading.typography.fontFamily"
					},
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "450"
				}
			},
			"caption": {
				"spacing": {
					"padding": {
						"top": "8px"
					}
				},
				"typography": {
					"fontSize": "14px",
					"fontWeight": "400"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": {
						"ref": "styles.elements.h1.typography.fontWeight"
					},
					"lineHeight": "1"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "clamp(22px, 1.625rem + ((1vw - 3px) * -0.536), 18px)",
					"lineHeight": "1.3"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"heading": {
				"css": "&.has-background { padding: 0; }",
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--eb-garamond)",
					"fontStyle": "normal",
					"fontWeight": "500"
				}
			},
			"link": {
				"color": {
					"text": "currentColor"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--20)",
			"padding": {
				"left": "var(--wp--preset--spacing--40)",
				"right": "var(--wp--preset--spacing--40)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--inter)",
			"fontSize": "16px",
			"fontStyle": "normal",
			"fontWeight": "400",
			"lineHeight": "1.65"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "header",
			"name": "header-hero",
			"title": "Hero Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "uncategorized",
			"name": "external-product-add-to-cart-with-options",
			"title": "External Product Add to Cart With Options"
		},
		{
			"area": "uncategorized",
			"name": "grouped-product-add-to-cart-with-options",
			"title": "Grouped Product Add to Cart With Options"
		},
		{
			"area": "uncategorized",
			"name": "simple-product-add-to-cart-with-options",
			"title": "Simple Product Add to Cart With Options"
		},
		{
			"area": "uncategorized",
			"name": "variable-product-add-to-cart-with-options",
			"title": "Variable Product Add to Cart With Options"
		},
		{
			"area": "uncategorized",
			"name": "mini-cart",
			"title": "Mini Cart"
		}
	]
}