{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Color 1",
					"slug": "theme-1"
				},
				{
					"color": "#f3eee8",
					"name": "Color 2",
					"slug": "theme-2"
				},
				{
					"color": "#c9dcee",
					"name": "Color 3",
					"slug": "theme-3"
				},
				{
					"color": "#25283d",
					"name": "Color 4",
					"slug": "theme-4"
				},
				{
					"color": "#691812",
					"name": "Color 5",
					"slug": "theme-5"
				}
			],
			"gradients": [
				{
					"gradient": "linear-gradient(135deg, rgb(255, 243, 214) 0%, rgb(200, 221, 242) 100%)",
					"name": "Casual Sale",
					"slug": "casual-sale"
				},
				{
					"gradient": "linear-gradient(135deg, rgb(255, 245, 223) 0%, rgb(214, 233, 245) 100%)",
					"name": "Weekend Edit",
					"slug": "weekend-edit"
				},
				{
					"gradient": "linear-gradient(135deg, rgb(244, 231, 223) 0%, rgb(248, 220, 228) 100%)",
					"name": "Soft Blush",
					"slug": "soft-blush"
				},
				{
					"gradient": "linear-gradient(135deg, rgb(225, 237, 228) 0%, rgb(214, 227, 245) 100%)",
					"name": "Coastal Morning",
					"slug": "coastal-morning"
				},
				{
					"gradient": "linear-gradient(135deg, rgb(255, 241, 196) 0%, rgb(230, 241, 217) 50%, rgb(207, 225, 244) 100%)",
					"name": "Summer Weekend",
					"slug": "summer-weekend"
				},
				{
					"gradient": "linear-gradient(135deg, rgb(214, 138, 113) 0%, rgb(245, 220, 204) 100%)",
					"name": "Terracotta Glow",
					"slug": "terracotta-glow"
				},
				{
					"gradient": "linear-gradient(135deg, rgb(214, 227, 213) 0%, rgb(242, 237, 225) 100%)",
					"name": "Sage Market",
					"slug": "sage-market"
				},
				{
					"gradient": "linear-gradient(135deg, rgb(223, 216, 238) 0%, rgb(244, 229, 234) 100%)",
					"name": "Lavender Haze",
					"slug": "lavender-haze"
				}
			]
		},
		"layout": {
			"wideSize": "1440px"
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "\"Uncut Sans Variable\"",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "300 700",
							"src": "file:./assets/fonts/Uncut-Sans/UncutSans-Variable.ttf"
						}
					],
					"fontFamily": "\"Uncut Sans Variable\", sans-serif",
					"name": "Uncut Sans Variable",
					"slug": "uncut-sans-variable"
				}
			],
			"fontSizes": [
				{
					"name": "XXS",
					"size": "14px",
					"slug": "xx-small"
				},
				{
					"name": "X Small",
					"size": "14px",
					"slug": "x-small"
				},
				{
					"name": "Small",
					"size": "16px",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "20px",
						"min": "18px"
					},
					"name": "Medium",
					"size": "24px",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "24px",
					"slug": "large"
				},
				{
					"name": "Extra Large",
					"size": "28px",
					"slug": "x-large"
				},
				{
					"fluid": true,
					"name": "2X Large",
					"size": "36px",
					"slug": "xx-large"
				},
				{
					"fluid": true,
					"name": "3X Large",
					"size": "48px",
					"slug": "xxx-large"
				}
			]
		}
	},
	"styles": {
		"blocks": {
			"core/button": {
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--theme-4)",
						"text": "var(--wp--preset--color--theme-1)"
					}
				},
				"border": {
					"radius": "4px",
					"width": "1px"
				},
				"typography": {
					"fontStyle": "normal",
					"fontWeight": "500",
					"letterSpacing": "0px",
					"textTransform": "none"
				},
				"variations": {
					"outline": {
						":hover": {
							"color": {
								"background": "var(--wp--preset--color--theme-4)",
								"text": "var(--wp--preset--color--theme-1)"
							}
						},
						"border": {
							"color": "currentColor",
							"radius": "4px",
							"style": "solid",
							"width": "1px"
						},
						"typography": {
							"fontStyle": "normal",
							"fontWeight": "500",
							"letterSpacing": "0px",
							"textTransform": "none"
						}
					}
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--uncut-sans-variable)",
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"core/site-title": {
				"typography": {
					"fontStyle": "normal",
					"fontWeight": "700"
				}
			},
			"woocommerce/product-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--uncut-sans-variable)"
				}
			}
		},
		"css": ".no-underline a { text-decoration: none; } a { text-decoration-thickness: 1px !important; text-underline-offset: .2em; } button:focus-visible, .wp-block-button__link:focus-visible { outline: 2px solid var(--wp--preset--color--theme-4); outline-offset: 2px; } button[disabled], .wp-block-button__link[disabled], .wp-block-button__link:disabled { opacity: 0.5; cursor: not-allowed; } button[disabled]:hover, .wp-block-button__link[disabled]:hover, .wp-block-button__link:disabled:hover { background-color: var(--wp--preset--color--theme-4); } .wc-block-add-to-cart-with-options-variation-selector-attribute-options__pill { border-color: color-mix(in srgb, currentColor 30%, transparent); border-radius: 0; } .wp-block-woocommerce-product-review-form .comment-reply-title { font-weight: unset; } .wc-block-product h2, .wc-block-product h3 { font-family: var(--wp--preset--font-family--uncut-sans-variable); font-size: var(--wp--preset--font-size--x-small) !important; font-weight: 500 !important; } .wp-block-woocommerce-product-button .wp-block-button__link, .wc-block-components-product-button .wp-block-button__link, .wc-block-components-product-button__button, .wp-block-woocommerce-product-button .wp-element-button, .wc-block-components-product-button .wp-element-button, .wp-block-woocommerce-add-to-cart-with-options .wp-element-button, .wc-block-add-to-cart-form .wp-element-button { border: 1px solid currentColor !important; border-radius: 4px !important; }",
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xxx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--uncut-sans-variable)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--uncut-sans-variable)"
		}
	},
	"customTemplates": [
		{
			"name": "template-home",
			"title": "Page: Home",
			"postTypes": [
				"page"
			]
		}
	]
}
